VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only - never prefix with VITE_ (would expose it to the client bundle)
GROQ_API_KEY=your-groq-api-key

# Optional: only needed if your local network requires a proxy for outbound
# HTTPS (e.g. a corporate network). Not needed in production. Leave unset if
# you don't already know you need this.
# HTTPS_PROXY=http://proxy-host:port
# HTTP_PROXY=http://proxy-host:port
